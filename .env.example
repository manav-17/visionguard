# VisionGuard Environment Configuration
# Copy this to .env and fill in your values

# ── CCTV Stream ───────────────────────────────────────────────────────────────
# WiFi CCTV RTSP URL — find this in your camera's app/settings
# Examples:
#   rtsp://admin:password@192.168.1.100:554/stream
#   rtsp://192.168.1.100:554/live/ch0
#   rtsp://admin:admin@192.168.0.1:554/h264/ch1/main/av_stream
# Use 0 for webcam (testing only)
RTSP_URL=rtsp://admin:password@192.168.1.100:554/stream

# ── MQTT ──────────────────────────────────────────────────────────────────────
MQTT_HOST=mqtt
MQTT_PORT=1883

# ── Optional: Twilio SMS alerts ───────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=your_sid
# TWILIO_AUTH_TOKEN=your_token
# TWILIO_FROM=+1234567890
# TWILIO_TO=+0987654321
